<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <!-- Default target framework for non-Windows platforms -->
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>Sportarr</AssemblyName>
    <RootNamespace>Sportarr</RootNamespace>
    <!-- Skip frontend build in CI (CI builds frontend separately) -->
    <SkipFrontendBuild Condition="'$(SkipFrontendBuild)' == ''">false</SkipFrontendBuild>
  </PropertyGroup>

  <!-- Automatic Frontend Build - runs before .NET build -->
  <!-- Builds React frontend and copies to wwwroot for serving -->
  <!-- Skip with: dotnet build -p:SkipFrontendBuild=true -->
  <Target Name="BuildFrontend" BeforeTargets="Build;Publish" Condition="'$(SkipFrontendBuild)' != 'true'">
    <Message Importance="High" Text="Building frontend..." />

    <!-- Check if npm is available -->
    <Exec Command="npm --version" ContinueOnError="true" StandardOutputImportance="Low">
      <Output TaskParameter="ExitCode" PropertyName="NpmExitCode" />
    </Exec>

    <!-- Install frontend dependencies if node_modules doesn't exist -->
    <Exec Command="npm ci --quiet" WorkingDirectory="../frontend" Condition="'$(NpmExitCode)' == '0' AND !Exists('../frontend/node_modules')" />

    <!-- Build frontend (outputs to _output/UI) -->
    <Exec Command="npm run build" WorkingDirectory="../frontend" Condition="'$(NpmExitCode)' == '0'" />

    <!-- Clean old frontend files from wwwroot -->
    <RemoveDir Directories="wwwroot/assets" Condition="Exists('wwwroot/assets')" />
    <Delete Files="wwwroot/index.html" Condition="Exists('wwwroot/index.html')" />

    <!-- Copy fresh frontend build to wwwroot -->
    <ItemGroup>
      <FrontendFiles Include="../_output/UI/**/*" />
    </ItemGroup>
    <Copy SourceFiles="@(FrontendFiles)" DestinationFolder="wwwroot/%(RecursiveDir)" Condition="'$(NpmExitCode)' == '0' AND Exists('../_output/UI')" />

    <Message Importance="High" Text="Frontend build complete." Condition="'$(NpmExitCode)' == '0'" />
    <Warning Text="npm not found - skipping frontend build. Install Node.js 20+ to build the UI." Condition="'$(NpmExitCode)' != '0'" />
  </Target>

  <!-- Expose internal matching helpers (LibraryImportService.CalculateMatchConfidence)
       to the unit test project so they can be tested without spinning up the full
       DbContext-backed service. -->
  <ItemGroup>
    <InternalsVisibleTo Include="Sportarr.Api.Tests" />
  </ItemGroup>

  <!-- Windows-specific: Enable Windows Forms for system tray support -->
  <!-- This requires the -windows target framework modifier -->
  <!-- EnableWindowsTargeting allows building Windows targets from Linux CI runners -->
  <PropertyGroup Condition="'$(RuntimeIdentifier)' == 'win-x64' OR '$(RuntimeIdentifier)' == 'win-x86' OR '$(RuntimeIdentifier)' == 'win-arm64'">
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <EnableWindowsTargeting>true</EnableWindowsTargeting>
  </PropertyGroup>

  <!-- Windows Service (SCM) integration: required by builder.Host.UseWindowsService() -->
  <ItemGroup Condition="'$(RuntimeIdentifier)' == 'win-x64' OR '$(RuntimeIdentifier)' == 'win-x86' OR '$(RuntimeIdentifier)' == 'win-arm64'">
    <PackageReference Include="Microsoft.Extensions.Hosting.WindowsServices" Version="8.0.1" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.OpenApi" Version="8.0.19" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Design" Version="9.0.9">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <PackageReference Include="Microsoft.EntityFrameworkCore.Sqlite" Version="9.0.9" />
    <!-- Use system SQLite instead of bundled e_sqlite3 to avoid "invalid opcode" crashes on older CPUs -->
    <PackageReference Include="SQLitePCLRaw.bundle_sqlite3" Version="2.1.10" />
    <PackageReference Include="Npgsql.EntityFrameworkCore.PostgreSQL" Version="9.0.4" />
    <PackageReference Include="Microsoft.Extensions.Http.Polly" Version="9.0.10" />
    <PackageReference Include="Swashbuckle.AspNetCore" Version="9.0.6" />
    <PackageReference Include="Serilog.AspNetCore" Version="8.0.3" />
    <PackageReference Include="Serilog.Sinks.File" Version="6.0.0" />
    <PackageReference Include="Serilog.Sinks.Console" Version="6.0.0" />
    <PackageReference Include="Ical.Net" Version="4.3.1" />
    <PackageReference Include="FluentValidation" Version="11.10.0" />
    <PackageReference Include="FluentValidation.DependencyInjectionExtensions" Version="11.10.0" />
    <!-- Legacy code pages (Windows-1252, ISO-8859-x) for IPTV M3U
         playlists that ship without a charset header. -->
    <PackageReference Include="System.Text.Encoding.CodePages" Version="9.0.0" />
    <!-- Fuzzy string matching for channel/EPG/event name resolvers. -->
    <PackageReference Include="FuzzySharp" Version="2.0.2" />
    <!-- BitTorrent infohash computation: lets us derive a torrent's real infohash
         locally (from the .torrent bytes or magnet) at add time, so the stored
         download id is the actual torrent rather than a guess from the client list. -->
    <PackageReference Include="MonoTorrent" Version="3.0.2" />
  </ItemGroup>

  <!-- Local agent worktrees may exist under src/Data/agents for experimentation.
       Exclude them from the main app project; the shipped plugin payload comes
       from the top-level ../agents directory below. -->
  <ItemGroup>
    <Compile Remove="Data/agents/**/*.cs" />
    <Content Remove="Data/agents/**" />
    <EmbeddedResource Remove="Data/agents/**" />
    <None Remove="Data/agents/**" />
  </ItemGroup>

  <!-- Local agent worktrees may exist under src/Data/agents for experimentation.
       Exclude them from the main app project; the shipped plugin payload comes
       from the top-level ../agents directory below. -->
  <ItemGroup>
    <Compile Remove="Data/agents/**/*.cs" />
    <Content Remove="Data/agents/**" />
    <EmbeddedResource Remove="Data/agents/**" />
    <None Remove="Data/agents/**" />
  </ItemGroup>

  <!-- Local agent worktrees may exist under src/Data/agents for experimentation.
       Exclude them from the main app project; the shipped plugin payload comes
       from the top-level ../agents directory below. -->
  <ItemGroup>
    <Compile Remove="Data/agents/**/*.cs" />
    <Content Remove="Data/agents/**" />
    <EmbeddedResource Remove="Data/agents/**" />
    <None Remove="Data/agents/**" />
  </ItemGroup>

  <!-- Sportarr.Data and Sportarr.Migrations.Postgres are separate projects nested under
       this one's directory. Without these excludes, the default SDK-style **/*.cs glob
       would compile their source files into THIS assembly too, in addition to their own
       - producing "type X exists in both Sportarr and Sportarr.Data" ambiguity errors for
       any downstream project (e.g. the test project) that references both assemblies. -->
  <ItemGroup>
    <Compile Remove="Sportarr.Data/**/*.cs" />
    <Content Remove="Sportarr.Data/**" />
    <EmbeddedResource Remove="Sportarr.Data/**" />
    <None Remove="Sportarr.Data/**" />
    <Compile Remove="Sportarr.Migrations.Postgres/**/*.cs" />
    <Content Remove="Sportarr.Migrations.Postgres/**" />
    <EmbeddedResource Remove="Sportarr.Migrations.Postgres/**" />
    <None Remove="Sportarr.Migrations.Postgres/**" />
  </ItemGroup>

  <!-- Include media server agents in build output -->
  <ItemGroup>
    <None Include="..\agents\**\*" CopyToOutputDirectory="PreserveNewest" LinkBase="agents" />
  </ItemGroup>

  <ItemGroup>
    <!-- SportarrDbContext, Models, and the SQLite migration history. -->
    <ProjectReference Include="Sportarr.Data\Sportarr.Data.csproj" />
    <!-- Referenced so its assembly ships in the publish output and is loadable at
         runtime when Sportarr__Database__Provider=postgres. Not used directly from
         app code - only by name via UseNpgsql's MigrationsAssembly(...) call. -->
    <ProjectReference Include="Sportarr.Migrations.Postgres\Sportarr.Migrations.Postgres.csproj" />
  </ItemGroup>

</Project>
